{
  "manifest_version": 3,
  "name": "ChatGPT Markdown Exporter",
  "version": "1.2.0",
  "description": "Local-only per-chat Markdown export for the currently open ChatGPT conversation.",
  "homepage_url": "https://github.com/The-Khan-Labs/chatgpt-markdown-exporter",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
